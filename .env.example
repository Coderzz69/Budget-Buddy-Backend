# Database
DATABASE_URL=postgresql://user:password@localhost:5432/budget_buddy
DIRECT_URL=postgresql://user:password@localhost:5432/budget_buddy

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Firebase (if using Firebase authentication)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# API Configuration
PORT=3000
NODE_ENV=development

# Authentication choice: "supabase" or "firebase"
AUTH_METHOD=supabase
